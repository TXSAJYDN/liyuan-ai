*.py[cod]
*$py.class

# 构建/发布产物
build/
dist/
*.egg-info/

# 测试/类型检查/格式化缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# ===== 虚拟环境 =====
.venv/
venv/
ENV/
env/

